import re
import sys

run_files = []
sample_files = []
sample_setup_dict = {}
sample_run_dict = {}
sample_organism_dict = {} # Updated from species to organism

sample_run_setup = config['sample_fastq_table']

# format of study_fq_tsv
# tab separated
# setup is either "paired" or "single"
# header of: sample_accession   run_accession_prefix    setup   organism
# example line:
# D3C_D0    D3C_D0_1__HJLT7DSX3_19270591_S73_L002   paired  human
# ending of run_accession taken from config.yaml
for line in open(sample_run_setup):
	if len(line.split('\t')) != 4:
		sys.exit(print('\n****************\nONLY ' + str(len(line.split('\t'))) + \
					' tab separated values in config[\'sample_fastq_table\']!!!!\n***************\n'))
	if 'sample_accession' in line:
		continue
	line = line.split('\t')
	if line[1] in run_files:
		sys.exit(print("Duplicated run: " + line[1] + "\nCheck sample input file for duplicates"))
	run_files.append(line[1])
	
	if line[0] not in sample_files:
		sample_files.append(line[0])
		
	sample_setup_dict[line[0]] = line[2].strip()
	sample_organism_dict[line[0]] = line[3].strip() # Store organism
	
	if line[0] not in sample_run_dict.keys():
		sample_run_dict[line[0]] = [line[1]]
	else:
		oval = sample_run_dict[line[0]]
		oval.append(line[1])
		sample_run_dict[line[0]] = oval

fq_dir = config['fastq_dir']

def return_fq(prefix):
	setup = sample_setup_dict[prefix]
	out = []
	if setup == 'single':
		out.append('fastq_trimmed/' + prefix + config['fqS_suffix'])
	else:
		out.append('fastq_trimmed/' + prefix + config['fq1_suffix'])
		out.append('fastq_trimmed/' + prefix + config['fq2_suffix'])
	return(out)

def salmon_input_maker(prefix):
	setup = sample_setup_dict[prefix]
	out = []
	if setup == 'single':
		out.append('-r ' + 'fastq_trimmed/' + prefix + config['fqS_suffix'])
	else:
		out.append('-1 ' + 'fastq_trimmed/' + prefix + config['fq1_suffix'])
		out.append('-2 ' + 'fastq_trimmed/' + prefix + config['fq2_suffix'])
	return(out)

# --- Dynamic Lookups based on Organism Custom Path ---
def get_salmon_index(wildcards):
	organism = sample_organism_dict[wildcards.sample]
	ann_path = config['references'][organism]['annotation_path'].rstrip('/')
	return f"{ann_path}/salmon_index_{organism}"

def get_star_index(wildcards):
	organism = sample_organism_dict[wildcards.sample]
	genome = config['references'][organism]['genome']
	gtf = config['references'][organism]['gtf']
	ann_path = config['references'][organism]['annotation_path'].rstrip('/')
	return f"{ann_path}/{genome}_{gtf}_STAR"

def get_gtf(wildcards):
	organism = sample_organism_dict[wildcards.sample]
	gtf = config['references'][organism]['gtf']
	ann_path = config['references'][organism]['annotation_path'].rstrip('/')
	return f"{ann_path}/{gtf}"
# -----------------------------------------------------

suffixes = [config['fq1_suffix'], config['fq2_suffix'], config['fqS_suffix']]

wildcard_constraints:
	run = '|'.join(run_files),
	sample = '|'.join(sample_files),
	suffix = '|'.join(suffixes)

SALMON_QUANT_OUTPUT = ['salmon_quant/' + sample + '/quant.sf'  \
	for sample in sample_files]

STAR_QUANT_OUTPUT = ['STAR_align/' + sample + '/' + sample + '_aligned.sortedByCoord.out.bam'  \
	for sample in sample_files]

FASTQC_OUTPUT = ['fastqc/' + sample + '.done' \
	for sample in sample_files]

BIGWIG_OUTPUT = ['bigwig/' + sample + '.bw'  \
	for sample in sample_files]


localrules: all, print_SALMON_quants, print_STAR_quants  

TARGETS = [
	'counts/gene_counts.csv.gz',
	'salmon_quant_output.tsv',
	'multiqc/multiqc_report.html'
]

if config.get('bigwig'):
	TARGETS.extend(BIGWIG_OUTPUT)

if config.get('star'):
	TARGETS.append('STAR_output.tsv')
	TARGETS.extend(STAR_QUANT_OUTPUT)

if config.get('kinship'):
    TARGETS.append('kinship/kinship_scores.kin0')
    TARGETS.append('STAR_output.tsv')

rule all:
	input:
		list(set(TARGETS)) 

rule aggregate_fq:
	input:
		lambda wildcards: expand(fq_dir + '/{run}{{suffix}}', run = sample_run_dict[wildcards.sample])
	output:
		temp(fq_dir + '/{sample}{suffix}')
	resources: disk="20GB", parallel=1
	shell:
		"""
		cat {input} > {output}
		"""

rule trim_fastq_se:
	input:
		fq_dir + '/{sample}' + config['fqS_suffix']
	output:
		temp('fastq_trimmed/{sample}' + config['fqS_suffix']),
	threads: 8
	resources: disk="20GB", parallel=1 
	conda: 'OGVFB_RNAseq.yml'
	shell:
		"""
		fastp --thread {threads} -i {input} -o {output}
		"""

rule trim_fastq_pe:
	input:
		r1 = ancient(fq_dir + '/{sample}' + config['fq1_suffix']),
		r2 = ancient(fq_dir + '/{sample}' + config['fq2_suffix'])
	output:
		r1 = temp('fastq_trimmed/{sample}' + config['fq1_suffix']),
		r2 = temp('fastq_trimmed/{sample}' + config['fq2_suffix']),
	threads: 8
	resources: disk="20GB", parallel=1
	conda: 'OGVFB_RNAseq.yml'
	shell:
		"""
		fastp --thread {threads} -i {input.r1} -I {input.r2} -o {output.r1} -O {output.r2}
		"""

rule download_references:
	output:
		touch("flags/download_{organism}.done")
	params:
		ann_path = lambda w: config['references'][w.organism]['annotation_path'].rstrip('/'),
		genome = lambda w: config['references'][w.organism]['genome'],
		gtf = lambda w: config['references'][w.organism]['gtf'],
		transcripts = lambda w: config['references'][w.organism]['transcripts'],
		genome_url = lambda w: config['references'][w.organism]['genome_url'],
		gtf_url = lambda w: config['references'][w.organism]['gtf_url'],
		transcripts_url = lambda w: config['references'][w.organism]['transcripts_url']
	shell:
		"""
		mkdir -p {params.ann_path}
		
		wget -c {params.genome_url} -O {params.ann_path}/{params.genome}
		wget -c {params.gtf_url} -O {params.ann_path}/{params.gtf}
		wget -c {params.transcripts_url} -O {params.ann_path}/{params.transcripts}
		"""

rule salmon_index:
	input:
		"flags/download_{organism}.done"
	output:
		touch("flags/salmon_index_{organism}.done")
	params:
		ann_path = lambda w: config['references'][w.organism]['annotation_path'].rstrip('/'),
		genome = lambda w: config['references'][w.organism]['genome'],
		transcripts = lambda w: config['references'][w.organism]['transcripts'],
		index_name = "salmon_index_{organism}"
	threads: 16
	priority: 500
	conda: 'OGVFB_RNAseq.yml'
	shell:
		"""
		tx="{params.ann_path}/{params.transcripts}"
		genome="{params.ann_path}/{params.genome}"
		out_dir="{params.ann_path}/{params.index_name}"
		
		grep "^>" <( gunzip -c $genome ) | cut -d " " -f 1 > {wildcards.organism}_decoys.txt
		sed -i.bak -e 's/>//g' {wildcards.organism}_decoys.txt
		cat $tx $genome > {wildcards.organism}_gentrome.fa.gz
		
		salmon index -t {wildcards.organism}_gentrome.fa.gz \
			-d {wildcards.organism}_decoys.txt \
			-p {threads} -i $out_dir -k 31
			
		rm {wildcards.organism}_decoys.txt {wildcards.organism}_decoys.txt.bak {wildcards.organism}_gentrome.fa.gz
		"""

rule STAR_index:
	input:
		"flags/download_{organism}.done"
	output:
		touch("flags/STAR_index_{organism}.done")
	params:
		ann_path = lambda w: config['references'][w.organism]['annotation_path'].rstrip('/'),
		genome = lambda w: config['references'][w.organism]['genome'],
		gtf = lambda w: config['references'][w.organism]['gtf']
	threads: 16
	priority: 500
	conda: 'OGVFB_RNAseq.yml'
	shell:
		"""
		fasta="{params.ann_path}/{params.genome}"
		gtf="{params.ann_path}/{params.gtf}"
		out_dir="{params.ann_path}/{params.genome}_{params.gtf}_STAR"
		
		mkdir -p $out_dir
		zcat $fasta > {wildcards.organism}_tmp_fasta
		zcat $gtf > {wildcards.organism}_tmp_gtf
		
		STAR --runThreadN {threads} \
			--runMode genomeGenerate \
			--genomeDir $out_dir \
			--sjdbGTFfile {wildcards.organism}_tmp_gtf \
			--sjdbOverhang 100 \
			--genomeFastaFiles {wildcards.organism}_tmp_fasta \
			--limitGenomeGenerateRAM=140090479317
			
		rm {wildcards.organism}_tmp_fasta
		rm {wildcards.organism}_tmp_gtf
		"""

rule salmon_quant:
	input:
		fq_files = lambda wildcards: return_fq(wildcards.sample),
		index_flag = lambda wildcards: f"flags/salmon_index_{sample_organism_dict[wildcards.sample]}.done"
	output:
		'salmon_quant/{sample}/quant.sf'
	params:
		input_command = lambda wildcards: salmon_input_maker(wildcards.sample),
		dir = 'salmon_quant/{sample}',
		index_dir = get_salmon_index
	priority: 100
	conda: 'OGVFB_RNAseq.yml'
	shell:
		"""
		salmon quant --index {params.index_dir} --libType A --seqBias --gcBias \
			--validateMappings \
			-p {threads} \
			--numGibbsSamples 100 \
			{params.input_command} \
			-o {params.dir}
		"""

rule STAR_align:
	input:
		index_flag = lambda wildcards: f"flags/STAR_index_{sample_organism_dict[wildcards.sample]}.done",
		fq_files = lambda wildcards: return_fq(wildcards.sample)
	output:
		bam = temp('STAR_align/{sample}/{sample}_aligned.sortedByCoord.out.bam'),
		bai = temp('STAR_align/{sample}/{sample}_aligned.sortedByCoord.out.bam.bai')
	conda: 'OGVFB_RNAseq.yml'
	params:
		scratch = '/lscratch/$SLURM_JOB_ID/STAR_align__{sample}/',
		out = 'STAR_align/{sample}/',
		index_dir = get_star_index
	threads: 8
	resources: disk="20GB"
	priority: 100
	shell:
		"""
		mkdir -p {params.out}
		STAR --runThreadN {threads} \
			--genomeDir {params.index_dir} \
			--readFilesIn {input.fq_files} \
			--outSAMtype BAM Unsorted \
			--readFilesCommand zcat \
			--outFileNamePrefix {params.out} \
			--outTmpDir {params.scratch} \
			--limitBAMsortRAM 32000000000 \
			--limitOutSJcollapsed 2000000
		mkdir -p {params.scratch}SAMSORT
		samtools sort -T {params.scratch}SAMSORT -o {output.bam} {params.out}Aligned.out.bam
		rm {params.out}Aligned.out.bam
		samtools index {output.bam}
		"""

rule deeptools_bamCoverage:
	input:
		bam = 'STAR_align/{sample}/{sample}_aligned.sortedByCoord.out.bam',
		bai = 'STAR_align/{sample}/{sample}_aligned.sortedByCoord.out.bam.bai'
	output:
		bw = 'bigwig/{sample}.bw'
	threads: 8
	priority: 200
	conda: 'OGVFB.deeptools.20260501.yml'
	shell:
		"""
		mkdir -p bigwig
		bamCoverage -b {input.bam} \
			--binSize 1 \
			-o {output.bw} \
			--normalizeUsing CPM \
			-p {threads}
		"""

rule print_SALMON_quants:
	input:
		quants=SALMON_QUANT_OUTPUT
	output:
		'salmon_quant_output.tsv'
	run:
		with open(output[0], 'w') as f:
			f.write('\n'.join(str(quant) for quant in input.quants))

rule print_STAR_quants:
	input:
		quants=STAR_QUANT_OUTPUT
	output:
		'STAR_output.tsv'
	run:
		with open(output[0], 'w') as f:
			f.write('\n'.join(str(quant) for quant in input.quants))

