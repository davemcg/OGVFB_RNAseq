rule index_reference:
    input:
        fasta = config['annotation_path'] + config['genome']
    output:
        fai = config['annotation_path'] + config['genome'] + ".fai",
        dict_file = config['annotation_path'] + re.sub(r'\.fa\.gz$|\.fasta\.gz$', '.dict', config['genome'])
    conda: 'OGVFB_RNAseq.yml'
    shell:
        """
        samtools faidx {input.fasta}
        gatk CreateSequenceDictionary -R {input.fasta} -O {output.dict_file}
        """

rule gatk_genotype_sample:
    input:
        bam = 'STAR_align/{sample}/{sample}_aligned.sortedByCoord.out.bam',
        ref = config['annotation_path'] + config['genome'],
        fai = config['annotation_path'] + config['genome'] + ".fai",
        dict_file = config['annotation_path'] + re.sub(r'\.fa\.gz$|\.fasta\.gz$', '.dict', config['genome'])
    output:
        vcf = 'gatk_calls/{sample}_filtered.vcf.gz'
    params:
        tmp = '/lscratch/$SLURM_JOB_ID/gatk_{sample}'
    conda: 'OGVFB.kinship.20260427.yml'
    shell:
        """
        mkdir -p {params.tmp}

        gatk AddOrReplaceReadGroups \
            -I {input.bam} -O {params.tmp}/rg.bam \
            -RGID {wildcards.sample} -RGLB lib1 -RGPL ILLUMINA -RGPU unit1 -RGSM {wildcards.sample}

        gatk MarkDuplicates \
            -I {params.tmp}/rg.bam -O {params.tmp}/marked.bam \
            -M {params.tmp}/metrics.txt

        gatk SplitNCigarReads \
            -R {input.ref} -I {params.tmp}/marked.bam -O {params.tmp}/split.bam

        gatk HaplotypeCaller \
            -R {input.ref} -I {params.tmp}/split.bam -O {params.tmp}/raw.vcf.gz \
            --dont-use-soft-clipped-bases -standard-min-confidence-threshold-for-calling 20.0

        gatk VariantFiltration \
            -R {input.ref} -V {params.tmp}/raw.vcf.gz -O {output.vcf} \
            --cluster-window-size 35 --cluster-size 3 \
            --filter-name "FS" --filter-expression "FS > 30.0" \
            --filter-name "QD" --filter-expression "QD < 2.0"

        rm -rf {params.tmp}
        """

rule plink_kinship:
    input:
        vcfs = expand('gatk_calls/{sample}_filtered.vcf.gz', sample=sample_files)
    output:
        table = 'kinship/kinship_scores.kin0'
    conda: 'OGVFB.kinship.20260427.yml'
    shell:
        """
        bcftools merge {input.vcfs} -Oz -o kinship/merged_raw.vcf.gz

        bcftools view kinship/merged_raw.vcf.gz \
            --types snps \
            --min-alleles 2 --max-alleles 2 \
            --targets ^chrX,chrY,X,Y \
            -Oz -o kinship/merged_filtered.vcf.gz

        plink2 --vcf kinship/merged_filtered.vcf.gz \
            --make-king-table \
            --out kinship/kinship_scores
        """
