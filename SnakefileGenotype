	input:
		lambda wildcards: return_fq(wildcards.sample)
	output:
		touch('fastqc/{sample}.done')
	params:
		outdir = 'fastqc/'
	threads: 2 
	priority: 100
	conda: 'OGVFB_RNAseq.yml' 
	shell:
		"""
		mkdir -p {params.outdir}
		fastqc -t {threads} -o {params.outdir} {input}
		"""

rule multiqc:
	input:
		fastqc=FASTQC_OUTPUT,
		salmon=SALMON_QUANT_OUTPUT
	output:
		"multiqc/multiqc_report.html"
	params:
		search_dirs = "fastqc/ STAR_align/ salmon_quant/",
		outdir = "multiqc/"
	conda: 'OGVFB_RNAseq.yml' 
	shell:
		"""
		multiqc {params.search_dirs} -o {params.outdir} -n multiqc_report.html
		"""




